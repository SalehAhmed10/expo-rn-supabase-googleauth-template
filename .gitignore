# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# Google OAuth credential downloads (never commit these)
client_secret_*.json
client_*.plist

# Firebase — commit android/app/google-services.json but ignore root-level downloads
/google-services.json
# FCM V1 service account key (sensitive — upload to EAS, never commit)
*firebase-adminsdk*.json

# EAS / build artifacts
build/

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
/android


# VS Code
.vscode/